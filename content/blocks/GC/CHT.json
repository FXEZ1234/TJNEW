{
  "type": "GenericCrafter",
  // 【必填】方块类型，固定值，指定为通用配方生产建筑，支持自定义输入输出

  "name": "谐振羰重整厂",
  // 【必填】游戏内显示名称，支持颜色格式（如[YELLOW]），玩家在建造菜单看到的名字


  "description": "超重型羰重整厂，消耗大量催化剂重整制备羰，为其他高级化工产品提供原料。",
  // 【可选】功能简介，鼠标悬浮在建造菜单时显示的简短说明

  "details": "[RED]",
  // 【可选】详细剧情/说明，点击建筑详情页显示的长文本，支持换行（\n）和颜色格式

  "size": 6,
  // 【必填】方块占地面积，3=3x3格，取值范围1-8的整数，影响碰撞体积和建造空间

  "health": 2100,
  // 【必填】基础生命值，建筑被破坏前能承受的总伤害，建议3x3建筑≥1000

  "armor": 26,
  // 【可选】基础护甲值，每次受到伤害时减免的固定数值，默认0，防御建筑推荐≥5

  "category": "crafting",
  // 【必填】建造菜单分类，可选值：crafting（生产）、defense（防御）、distribution（运输）、liquid（液体）、power（电力）、units（单位）、effects（特效）

  "research": "BHT",
  // 【可选】前置研究节点ID，玩家需先解锁该研究才能建造此建筑，不填则开局可造

  "requirements": [
    { "item": "NI", "amount": 80 },
    { "item": "MO", "amount": 60 },
    { "item": "CG", "amount": 50 },
    { "item": "titanium", "amount": 30 }
  ],
  // 【必填】建造材料列表，每个元素包含item（物品ID）和amount（数量），支持模组物品

  "hasPower": true,
  // 【条件必填】启用电力系统，用电建筑必须设为true，配合consumes.power使用

  "hasLiquids": true,
  // 【条件必填】启用液体系统，带液体输入/输出的建筑必须设为true

  "hasItems": true,
  // 【可选】禁用物品系统，纯液体处理建筑设为false，隐藏物品输入输出口

    "itemCapacity": 60,
  // 物品容量
  "outputItem": null,
  // 无固体输出必须显式声明为null
  "liquidCapacity": 7680,
  // 【条件必填】液体总缓存容量，单位：滴，必须大于单批次输入+输出的液体总量，预留缓存空间

  "craftTime": 480,
  // 【必填】单批次生产周期，单位：帧（游戏固定60帧=1秒），60=1秒完成1次生产

  "craftEffect": "smeltsmoke",
  // 【补全】化工冶炼类原版合法烟雾特效
  
  "ambientSound": "smelt",
  // 【补全】冶炼类适配工作音效


   "consumes": {
    "power": 150.0,
    // 每帧电力消耗
    "items": [
      { "item": "C", "amount": 50 },
      //每轮生产消耗

      { "item": "CFHJ", "amount": 1 }
            //每轮生产消耗

    ],
    "liquid": {
      "liquid": "HCO",
      "amount": 2.0
      // 【修改】每帧消耗0.25单位水煤气(HCO)
    }
    // 最终输入配方：0.25 HCO/帧 + 1 C/轮 + 3.0电/帧
  },
  "outputLiquids": [
    { "liquid": "CO", "amount": 4.0 }
    // 【修改】只产羰(CO)，每帧产出0.3单位，完全匹配你的要求
  ],
  "rotate": true,
  // 【可选】开启方块旋转功能，玩家可在建造时旋转建筑，调整输入输出方向

  "canOverdrive": true,
  // 【可选】是否支持超频，设为true时可被超频处理器加速，生产时长与超频倍率成反比，功耗与超频倍率平方成正比

  "solid": true,
  // 【必填】是否为实心碰撞体，设为true时单位/子弹无法穿过，生产建筑通常设为true

  "placeableLiquid": false,
  // 【可选】是否可放置在液体上，设为true时可在水面/岩浆面建造，水下建筑专用

  "breakable": true
  // 【必填】是否可被破坏，设为false时建筑无敌，仅核心/屏障等特殊建筑设为false
}