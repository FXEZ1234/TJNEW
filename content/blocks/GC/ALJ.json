{
  "name": "煤焦化研究所",
  // 【必填】游戏内显示名称，中文必须加英文半角双引号

  "description": "前线小型焦化设备，专为前沿阵地设计，部署门槛低、占地面积小，可在前线完成煤的焦化，为阵地提供焦炭与煤焦油。",
  // 【可选】基础功能描述，显示在方块详情页

  "details": "【战时工业部前线档案】\n专为无后方焦炭补给的前沿阵地设计，虽然产能偏低，但可在前线直接完成煤的焦化，是阵地工业体系的核心前置设备。",
  // 【可选】补充说明/轻量化剧情，研究解锁后完整显示
  // 【技巧】换行用 \n

  "type": "GenericCrafter",
  // 【必填】方块类型，字符串

  "size": 3,
  // 【必填】方块占地面积，整数

  "health": 1000,
  // 【必填】方块基础生命值，整数

  "armor": 6,
  // 【可选】方块防御护甲，整数

  "category": "crafting",
  // 【必填】科技树分类，字符串

  "research": "DYL",
  // 【可选】前置解锁研究，字符串

  "requirements": [
    {
      "item": "NI",
      // 【必填】需求物品ID，字符串
      "amount": 70
      // 【必填】需求物品数量，整数
    },
    {
      "item": "MO",
      "amount": 50
    },
    {
      "item": "CG",
      "amount": 40
    }
  ],
  // 【必填】方块建造需求，数组

  "hasPower": true,
  // 【必填】是否消耗电力，布尔值

  "hasItems": true,
  // 【必填】是否处理固体物品，布尔值

  "hasLiquids": true,
  // 【必填】是否处理流体，布尔值

  "craftTime": 60,
  // 【必填】单轮生产周期，整数

  "craftEffect": "smeltsmoke",
  // 【替换无效特效】冶炼类官方合法烟雾特效

  "ambientSound": "smelt",
  // 【可选】工作时的环境音效，字符串
  // 【说明】冶炼类适配 smelt

  "consumes": {
    "power": 0.1,
    // 沿用原电力消耗数值
    "items": [
      {
        "item": "coal",
        // 【必填】输入物品ID，字符串
        "amount": 4
        // 【必填】单轮生产输入数量，整数
      }
    ]
  },
  // 标准合法消耗写法，替代旧版非法字段

  "outputItem": {
    "item": "C",
    // 【必填】输出物品ID，字符串
    "amount": 1
    // 【必填】单轮生产输出数量，整数
  },
  // 标准单物品输出格式

  "outputLiquid": {
    "liquid": "MJY",
    // 【必填】输出流体ID，字符串
    "amount": 0.25
    // 【必填】每帧流体输出量，数值
  },
  // 【可选】单流体输出，对象
  // 【无输出】固定填 null

  "canOverdrive": true,
  // 【可选】是否可被超频项目超频，布尔值

  "solid": true,
  // 【可选】是否为实心方块，布尔值

  "placeableLiquid": false,
  // 【可选】是否可放置在液体表面，布尔值

  "placeableOn": "both",
  // 【可选】可放置地形，字符串

  "breakable": true,
  // 【可选】是否可被敌方单位破坏，布尔值

  "buildTime": 60
  // 【可选】建造所需时间，整数
}