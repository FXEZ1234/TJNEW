{
  "type": "GenericCrafter",
  "name": "标准水电解制氢站",
  "description": "集约化电解水设备，快速电解水，为工业化提供充足氢气和臭氧",
  "details": "为避免爆燃，多余气体直接排空，注意损耗",
  "size": 4,
  "health": 8000,
  "armor": 6,
  "category": "crafting",
  "research": "DYL",
  "requirements": [
    { "item": "NI", "amount": 80 },
    { "item": "MO", "amount": 60 },
    { "item": "CG", "amount": 50 },
    { "item": "CFHJ", "amount": 30 }
  ],
  "hasPower": true,
  "hasLiquids": true,
  "hasItems": false,
  "liquidCapacity": 500,
  "craftTime": 60,
  // 输出两种液体，和你之前的results一致
  "outputLiquids": [
    "hydrogen/2.0",
    "ozone/1.0"
  ],
  // 为每个输出指定独立方向，右和左，避免混合
  "liquidOutputDirections": [1, 3],
  // 关闭多余液体丢弃，避免浪费
  "dumpExtraLiquid": false,
  // 消耗配置：电力和输入的水
  "consumes": {
    "power": 1.6,
    "liquid": "water/3"
  },
  "rotate": true,
  // 新增：开启方块旋转功能，和原版电解机一致
  "canOverdrive": true,
  "solid": true,
  "placeableLiquid": false,
  "breakable": true
}