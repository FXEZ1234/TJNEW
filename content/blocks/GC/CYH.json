  // 液体总缓存容量
  "craftTime": 480,
  // 【必填】单轮生产周期，整数

  "craftEffect": "smeltsmoke",
  // 【替换无效特效】冶炼类官方合法烟雾特效

  "ambientSound": "smelt",
  // 【可选】工作时的环境音效，字符串
  // 【说明】冶炼类适配 smelt

  "consumes": {
    "power": 300.0,
    // 电力消耗
 "liquids": [
      {
        "liquid": "HCO",
        "amount": 2.0
      },
      {
        "liquid": "water",
        "amount": 2.0
      }
    ],


        "items": [
      {
        "item": "CFHJ",
        // 生产输入原料ID
        "amount": 1
        // 单次生产消耗数量
      }  
    ]
  },
  // 标准合法消耗写法，替代旧版非法字段

  "outputLiquid": {
    "liquid": "hydrogen",
    // 【必填】输出流体ID，字符串
    "amount": 4.0
    // 【必填】每帧流体输出量，数值
  },
  // 【可选】单流体输出，对象
  // 【无输出】固定填 null

  "canOverdrive": true,
  // 【可选】是否可被超频项目超频，布尔值

  "solid": true,
  // 【可选】是否为实心方块，布尔值

  "placeableLiquid": false,
  // 【可选】是否可放置在液体表面，布尔值

  "placeableOn": "both",
  // 【可选】可放置地形，字符串

  "breakable": true,
  // 【可选】是否可被敌方单位破坏，布尔值

  "buildTime": 60
  // 【可选】建造所需时间，整数
}