  "type": "GenericCrafter",
  // 【必填】方块类型，字符串

  "size": 2,
  // 【必填】方块占地面积，整数

  "health": 200,
  // 【必填】方块基础生命值，整数

  "armor": 1,
  // 【可选】方块防御护甲，整数

  "category": "crafting",
  // 【必填】科技树分类，字符串

  "research": "ACC",
  // 【可选】前置解锁研究，字符串

  "requirements": [
    {
      "item": "NI",
      // 【必填】需求物品ID，字符串
      "amount": 70
      // 【必填】需求物品数量，整数
    },
    {
      "item": "MO",
      "amount": 50
    },
    {
      "item": "CG",
      "amount": 40
    }
  ],
  // 【必填】方块建造需求，数组

  "hasPower": true,
  // 【必填】是否消耗电力，布尔值

  "hasItems": true,
  // 【必填】是否处理固体物品，布尔值

  "hasLiquids": true,
  // 【必填】是否处理流体，布尔值
