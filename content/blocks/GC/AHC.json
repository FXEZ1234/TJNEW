{
  "name": "沙尘收集器",
  // 【必填】游戏内显示名称，中文必须加英文半角双引号

  "description": "收集空气中的沙尘，无需额外原料，仅消耗电力即可稳定产出沙",
  // 【可选】基础功能描述，显示在方块详情页

  "details": "所以为什么不直接挖呢",
  // 【可选】补充说明/轻量化剧情，研究解锁后完整显示

  "type": "GenericCrafter",
  // 【必填】方块类型，字符串
  // 【可用值】GenericCrafter（通用生产）、Smelter（熔炉）、Mixer（混合器）

  "size": 2,
  // 【必填】方块占地面积，整数
  // 【取值范围】1 ~ 5，对应1x1~5x5的格子尺寸

  "health": 800,
  // 【必填】方块基础生命值，整数
  // 【取值范围】100 ~ 10000

  "armor": 5,
  // 【可选】方块防御护甲，整数
  // 【取值范围】0 ~ 100，数值越高受到的伤害越低

  "category": "crafting",
  // 【必填】科技树分类，字符串
  // 【可用值】crafting（生产类）、turret（炮塔类）、defense（防御类）、liquid（液体类）、power（电力类）、effect（功能类）、unit（单位类）

  "research": "DYL",
  // 【可选】前置解锁研究，字符串
  // 【限制】仅填写对应物品/方块/指令的纯ID

  "requirements": [
    {
      "item": "NI",
      // 【必填】需求物品ID，字符串
      "amount": 80
      // 【必填】需求物品数量，整数
    },
    {
      "item": "MO",
      "amount": 50
    },
    {
      "item": "CG",
      "amount": 40
    }
  ],
  // 【必填】方块建造需求，数组
  // 【无需求】填空数组 []

  "hasPower": true,
  // 【必填】是否消耗电力，布尔值
  // 【逻辑】生产类方块必须为true

  "powerUse": 4,
  // 【可选】每帧电力消耗，数值
  // 【计算公式】游戏内显示的每秒电力消耗 ÷ 60 = 代码值

  "consumePowerAdditive": false,
  // 【可选】是否必须满功率才能工作，布尔值
  // 【逻辑】true=不满电完全不工作，false=功率不足时降速生产

  "hasItems": true,
  // 【必填】是否处理固体物品，布尔值

  "hasLiquids": false,
  // 【必填】是否处理流体，布尔值

  "craftTime": 60,
  // 【必填】单轮生产周期，整数
  // 【单位】帧（60帧 = 1秒）

  "updateEffect": "pulverize",
  // 【可选】工作时的视觉特效，字符串
  // 【可用值】pulverize（粉碎粉尘）、smeltersteam（冶炼蒸汽）、melt（熔化特效）、fire（火焰）、plasma（等离子）、none（无特效）

  "ambientSound": "craft",
  // 【可选】工作时的环境音效，字符串
  // 【可用值】craft（生产声）、smelt（冶炼声）、hum（电流声）、none（无声）

  "items": [],
  // 【必填】固体输入列表，数组
  // 【无输入】填空数组 []

  "outputItem": {
    "item": "sand",
    // 【必填】输出物品ID，字符串
    "amount": 10
    // 【必填】单轮生产输出数量，整数
  },
  // 【可选】单物品输出，对象
  // 【说明】多物品输出用 outputItems

  "outputLiquid": null,
  // 【可选】单流体输出，对象
  // 【无输出】固定填 null

  "canOverdrive": true,
  // 【可选】是否可被超频项目超频，布尔值

  "inverted": false,
  // 【可选】是否反转逻辑，布尔值
  // 【说明】生产类方块无需反转

  "solid": true,
  // 【可选】是否为实心方块，布尔值
  // 【逻辑】true=单位无法穿过

  "placeableLiquid": false,
  // 【可选】是否可放置在液体表面，布尔值

  "placeableOn": "both",
  // 【可选】可放置地形，字符串
  // 【可用值】both（陆地+液体）、land（仅陆地）、liquid（仅液体）

  "breakable": true,
  // 【可选】是否可被敌方单位破坏，布尔值

  "buildCostMultiplier": 1.0,
  // 【可选】建造成本倍率，浮点数
  // 【取值范围】0.1 ~ 10.0

  "buildTime": 60
  // 【可选】建造所需时间，整数
  // 【单位】帧（60帧 = 1秒）
}