{
  "type": "GenericCrafter",
  // 【必填】方块类型
  // 【说明】生产类工厂固定使用 GenericCrafter

  "name": "电子稳定厂",
  // 【必填】游戏内显示名称
  // 【说明】支持中文，会直接显示在建造菜单和方块信息面板

  "description": "基础型电子稳定设备",
  // 【可选】基础功能描述
  // 【说明】显示在方块详情页，简要介绍方块用途

  "details": "基础型电子稳定设备",
  // 【可选】补充说明/轻量化剧情
  // 【说明】研究解锁后完整显示，支持 \n 换行

  "size": 2,
  // 【必填】方块占地面积
  // 【取值范围】1 ~ 5，对应 1x1 ~ 5x5 的格子尺寸

  "health": 900,
  // 【必填】方块基础生命值
  // 【说明】数值越高越抗打，原版 3x3 工厂默认值为 800~1200

  "armor": 5,
  // 【可选】方块防御护甲
  // 【说明】数值越高受到的伤害越低，默认值为 0

  "category": "crafting",
  // 【必填】科技树分类
  // 【可用值】crafting（生产类）、turret（炮塔类）、defense（防御类）、liquid（液体类）、power（电力类）、effect（功能类）、unit（单位类）

  "research": "ASI",
  // 【可选】前置解锁研究
  // 【说明】仅填写对应研究的纯 ID，不添加其他内容

  "requirements": [
    {
      "item": "NI",
      // 【必填】需求物品 ID
      "amount": 60
      // 【必填】需求物品数量
    },
    {
      "item": "MO",
      "amount": 40
    },
    {
      "item": "CG",
      "amount": 30
    }
  ],
  // 【必填】方块建造需求
  // 【说明】数组格式，无建造需求填空数组 []

  "hasPower": true,
  // 【必填】是否处理电力
  // 【逻辑】消耗电力或生产电力必须为 true

  "hasItems": true,
  // 【必填】是否处理固体物品
  // 【逻辑】涉及物品输入输出必须为 true

  "hasLiquids": false,
  // 【必填】是否处理流体
  // 【逻辑】涉及液体输入输出必须为 true

  "consumes": {
    // 【核心】输入配置包裹对象
    // 【说明】所有电力、物品、流体输入都放在这里

    "power": 900.0,
    // 【可选】每帧电力消耗
    // 【计算公式】游戏内显示的每秒电力消耗 ÷ 60 = 代码值

    "items": [
      // 【可选】固体输入列表
      // 【说明】无固体输入填空数组 []

      {
        "item": "silicon",
        // 【必填】输入物品 ID
        "amount": 1
        // 【必填】单轮生产输入数量
      }
    ]
  },

  "craftTime": 60,
  // 【必填】单轮生产周期
  // 【单位】帧（60帧 = 1秒）

  "updateEffect": "none",
  // 【兼容】更新特效
  // 【说明】为避免报错，固定填 "none"

  "craftEffect": "smeltsmoke",
  // 【可选】工作时的视觉特效
  // 【可用值】smeltsmoke（冶炼烟雾）、pulverize（粉碎粉尘）、melt（熔化特效）、none（无特效）

  "outputItem": {
    // 【可选】单物品输出
    // 【说明】多物品输出用 outputItems

    "item": "WDZT",
    // 【必填】输出物品 ID
    "amount": 1
    // 【必填】单轮生产输出数量
  },

  "outputLiquid": null,
  // 【可选】单流体输出
  // 【说明】无流体输出固定填 null

  "canOverdrive": true,
  // 【可选】是否可被超频项目超频
  // 【逻辑】true=可以超频，false=不可超频

  "solid": true,
  // 【可选】是否为实心方块
  // 【逻辑】true=单位无法穿过，false=单位可以穿过

  "placeableLiquid": false,
  // 【可选】是否可放置在液体表面
  // 【逻辑】true=可放水面，false=仅可放陆地

  "breakable": true,
  // 【可选】是否可被敌方单位破坏
  // 【逻辑】true=可被破坏，false=无敌

  "buildTime": 120
  // 【可选】建造所需时间
  // 【单位】帧（60帧 = 1秒）
}