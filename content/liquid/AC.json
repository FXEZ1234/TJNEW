  "name": "工业酸",
  // 【必填】游戏内显示名称，中文必须加英文半角双引号

  "description": "以氨为核心原料合成的复合型工业酸，具备强腐蚀性与催化活性，四大核心用途：1. 高利用率冶金浮选 2. 特种合金合成原料 3. 金属表面酸洗除杂 4. 阵地腐蚀流体武器，适配全链条战时工业体系。",
  // 【可选】流体基础描述，显示在流体详情页

  "details": "【战时工业部核心档案】\n现代化工体系的核心命脉，从镍、钼矿的浮选提纯，到伯承合金的酸洗除杂，再到阵地腐蚀武器的制备，全产业链均依赖工业酸的稳定供给，氨合成线与酸合成线是工厂最高优先级保护的目标。",
  // 【可选】补充剧情/说明文本，研究解锁后完整显示
  // 【技巧】换行用 \n

  "color": "ffff00",
  // 【必填】流体显示颜色，字符串
  // 【格式】十六进制RGB值，必须去除#号，加英文半角双引号

  "gas": false,
  // 【必填】物态标识，布尔值
  // 【取值】true=气态流体，false=液态流体

  "flammability": 0.0,
  // 【可选】可燃性，浮点数
  // 【取值范围】0.0 ~ 5.0，数值越高越容易被点燃

  "explosiveness": 0.15,
  // 【可选】爆炸性，浮点数
  // 【取值范围】0.0 ~ 5.0，数值越高爆炸威力越强

  "temperature": 0.4,
  // 【可选】基础温度，浮点数
  // 【取值范围】-2.0 ~ 2.0，0=游戏内常温，正数=高温，负数=低温

  "heatCapacity": 0.7,
  // 【可选】热容，浮点数
  // 【取值范围】0.1 ~ 5.0，数值越高温度越难改变

  "viscosity": 0.5,
  // 【可选】粘度，浮点数
  // 【取值范围】0.1 ~ 1.0，数值越高流动速度越慢

  "corrosiveness": 0.9,
  // 【可选】腐蚀性，浮点数
  // 【取值范围】0.0 ~ 1.0，数值越高对方块/单位的腐蚀伤害越强

  "effect": "corrosive",
  // 【可选】流动/接触特效，字符串
  // 【可用值】burning（燃烧）、fire（火焰）、steam（蒸汽）、freezing（冰冻）、plasma（等离子）、corrosive（腐蚀）、none（无特效）

  "sound": "liquidflow",
  // 【可选】流动音效，字符串
  // 【可用值】liquidflow（液态流体流动音效）、gasflow（气态流体流动音效）、none（无声）

  "lightColor": "ffff00",
  // 【可选】发光颜色，字符串
  // 【格式】十六进制RGB值，必须去除#号，加英文半角双引号

  "lightOpacity": 0.3,
  // 【可选】发光不透明度，浮点数
  // 【取值范围】0.0 ~ 1.0，0=完全不发光，1=强光

  "canStayOn": ["solid", "liquid"],
  // 【可选】可附着的表面类型，数组
  // 【可用值】"solid"（固体方块表面）、"liquid"（液体表面）、"air"（空气）

  "barrier": false,
  // 【可选】是否为屏障流体，布尔值
  // 【逻辑】true=会阻挡单位/子弹，false=普通流体

  "research": "NH"
  // 【可选】前置解锁研究，字符串
  // 【限制】必须填写对应物品/方块/流体的ID
}