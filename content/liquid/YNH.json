{
  "id": "LNH",
  // 【必填】唯一标识符，必须加英文半角双引号

  "name": "液氨",
  // 【必填】游戏内显示名称，中文必须加英文半角双引号

  "description": "工业级高级冷冻液，由氨气经高压低温液化制得，汽化潜热大、制冷效率高，是工业冷冻、超导设备冷却、高精度生产装置温控的核心介质。",
  // 【可选】流体基础描述，显示在流体详情页

  "details": "【工业制冷技术手册】\n工业主流中低温制冷剂，可稳定维持-33℃的低温环境，是唯一能长期适配钐磁超导阵列、高精度雷达、超算核心的低成本冷冻液，是高端工业装置的核心保障耗材。",
  // 【可选】补充剧情/说明文本，研究解锁后完整显示

  "color": "6699cc",
  // 【必填】流体显示颜色，十六进制RGB值

  "gas": false,
  // 【必填】物态标识，true=气态，false=液态

  "flammability": 0.1,
  // 【可选】可燃性，数值越高越易燃

  "explosiveness": 0.15,
  // 【可选】爆炸性，数值越高爆炸威力越强

  "temperature": -1.8,
  // 【可选】基础温度，0=常温，负数为低温，符合游戏-2.0~2.0取值范围

  "heatCapacity": 1.4,
  // 【可选】热容，数值越高温度越难改变，适配液氨高制冷能力属性

  "viscosity": 0.3,
  // 【可选】粘度，数值越高流动越慢

  "corrosiveness": 0.25,
  // 【可选】腐蚀性，0=无腐蚀

  "effect": "freezing",
  // 【可选】流动/接触特效，适配低温冷冻属性

  "sound": "liquidflow",
  // 【可选】流动音效，液态流体固定用liquidflow

  "lightColor": "6699cc",
  // 【可选】发光颜色

  "lightOpacity": 0.3,
  // 【可选】发光不透明度

  "canStayOn": ["solid"],
  // 【可选】可附着的表面类型，液氨仅在固体表面稳定存在

  "barrier": false,
  // 【可选】是否为屏障流体

  "research": "NH"
  // 【可选】前置解锁研究
