{
  "id": "NH",
  // 【必填】唯一标识符，必须加英文半角双引号

  "name": "氨",
  // 【必填】游戏内显示名称，中文必须加英文半角双引号

  "description": "由氢和氮合成，是常用还原性流体，液氨和酸的原料。",
  // 【可选】流体基础描述，显示在流体详情页

  "details": "【工业化工手册】\n现代化工体系的基石，从基础矿物酸洗、金属表面处理，到高端合金催化合成，全工业链条均依赖氨的稳定供给，是工厂核心保障级原料。",
  // 【可选】补充剧情/说明文本，研究解锁后完整显示

  "color": "aaddff",
  // 【必填】流体显示颜色，十六进制RGB值

  "gas": true,
  // 【必填】物态标识，true=气态，false=液态

  "flammability": 0.15,
  // 【可选】可燃性，数值越高越易燃

  "explosiveness": 0.2,
  // 【可选】爆炸性，数值越高爆炸威力越强

  "temperature": 0.2,
  // 【可选】基础温度，0=常温

  "heatCapacity": 0.6,
  // 【可选】热容，数值越高温度越难改变

  "viscosity": 0.18,
  // 【可选】粘度，数值越高流动越慢

  "corrosiveness": 0.3,
  // 【可选】腐蚀性，0=无腐蚀

  "effect": "steam",
  // 【可选】流动/接触特效，适配气态挥发属性

  "sound": "gasflow",
  // 【可选】流动音效，气态流体固定用gasflow

  "lightColor": "ffffff",
  // 【可选】发光颜色

  "lightOpacity": 0.1,
  // 【可选】发光不透明度

  "canStayOn": ["air"],
  // 【可选】可附着的表面类型，气态仅存在于空气中

  "barrier": false,
  // 【可选】是否为屏障流体

  "research": "DYL"
  // 【可选】前置解锁研究
}