{
  "id": "HCO",
  // 【必填】唯一标识符，必须加英文半角双引号

  "name": "水煤气",
  // 【必填】游戏内显示名称，中文必须加英文半角双引号

  "description": "由焦炭和水反应生产，用于提供氢气和一氧化碳。",
  // 【可选】流体基础描述，显示在流体详情页

  "details": "【工业化工手册】\n水煤气是石油供应链中断后的核心替代能源，制备门槛低，可在中小型工厂实现量产，单套气化装置即可满足常规冶炼集群的基础能源需求，是战时工业体系的基础能源保障。",
  // 【可选】补充剧情/说明文本，研究解锁后完整显示

  "color": "e6f2ff",
  // 【必填】流体显示颜色，十六进制RGB值

  "gas": true,
  // 【必填】物态标识，true=气态，false=液态

  "flammability": 0.85,
  // 【可选】可燃性，数值越高越易燃

  "explosiveness": 0.6,
  // 【可选】爆炸性，数值越高爆炸威力越强

  "temperature": 0.3,
  // 【可选】基础温度，0=常温

  "heatCapacity": 0.45,
  // 【可选】热容，数值越高温度越难改变

  "viscosity": 0.15,
  // 【可选】粘度，数值越高流动越慢

  "corrosiveness": 0.0,
  // 【可选】腐蚀性，0=无腐蚀

  "effect": "burning",
  // 【可选】流动/接触特效，适配可燃属性

  "sound": "gasflow",
  // 【可选】流动音效，气态流体固定用gasflow

  "lightColor": "ffffff",
  // 【可选】发光颜色

  "lightOpacity": 0.1,
  // 【可选】发光不透明度

  "canStayOn": ["air"],
  // 【可选】可附着的表面类型，气态仅存在于空气中

  "barrier": false,
  // 【可选】是否为屏障流体

  "research": "DYL"
  // 【可选】前置解锁研究
}